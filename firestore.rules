rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isNEUEmail() {
      return request.auth.token.email.matches('.*@neu\\.edu\\.ph$');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && isNEUEmail() && getUserData().role == role;
    }

    function isAdmin()   { return hasRole('admin'); }
    function isFaculty() { return hasRole('faculty'); }
    function isStudent() { return hasRole('student'); }

    function isNotBlocked() {
      return isAuthenticated() && getUserData().isBlocked == false;
    }

    function canFacultyManageMOA() {
      return isFaculty() && isNotBlocked() && getUserData().canManageMOA == true;
    }

    function isApprovedStatus(status) {
      return status.matches('^APPROVED.*');
    }

    match /users/{userId} {
      // A user can always read their own doc (needed for live role sync via onSnapshot).
      // isNotBlocked() is intentionally excluded here — it calls get() on this same doc,
      // causing a circular dependency that silently kills real-time listeners.
      allow read:   if isAuthenticated() && isNEUEmail()
                       && (request.auth.uid == userId || isAdmin() && isNotBlocked());
      allow create: if isAuthenticated() && isNEUEmail() && request.auth.uid == userId;
      allow update: if isAuthenticated() && isNEUEmail()
                       && (request.auth.uid == userId || isAdmin() && isNotBlocked());
      allow list:   if isAdmin() && isNotBlocked();
    }

    match /moas/{moaId} {
      // All authenticated NEU users can read — role filtering is enforced in app code
      allow read, list: if isAuthenticated() && isNEUEmail();
      allow create: if isAdmin() && isNotBlocked() || canFacultyManageMOA();
      allow update: if isAdmin() && isNotBlocked() || canFacultyManageMOA();
      allow delete: if isAdmin() && isNotBlocked();

      match /auditTrail/{entryId} {
        allow read, list: if isAuthenticated() && isNEUEmail();
        allow create:     if isAdmin() && isNotBlocked() || canFacultyManageMOA();
        allow update:     if false;
        allow delete:     if isAdmin() && isNotBlocked();
      }

      match /notes/{noteId} {
        allow read, list: if isAuthenticated() && isNEUEmail();
        allow create:     if isAdmin() && isNotBlocked();
        allow update:     if false;
        allow delete:     if isAdmin() && isNotBlocked();
      }
    }

    // Allow collectionGroup query on auditTrail (admin only)
    match /{path=**}/auditTrail/{entryId} {
      allow read: if isAdmin() && isNotBlocked();
    }
  }
}
